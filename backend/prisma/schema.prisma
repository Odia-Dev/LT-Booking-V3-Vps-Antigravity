datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// -----------------------------------------------------------------------------
// Branch Model: Dealership Locations
// -----------------------------------------------------------------------------
model Branch {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  code           String   @unique
  address        String
  city           String
  district       String
  state          String
  pincode        String
  phone          String
  email          String
  googleMapsUrl  String
  workingHours   String   @default("9:00 AM - 7:00 PM")
  latitude       Float?
  longitude      Float?
  managerName    String?
  managerPhone   String?
  salesManager   String?
  serviceManager String?
  sortOrder      Int      @default(0)
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leads               Lead[]
  testDrives          TestDrive[]
  bookings            Booking[]
  preferredUsers      User[]               @relation("UserPreferredBranch")
  deliveries          Delivery[]
  financeApplications FinanceApplication[]
}

// -----------------------------------------------------------------------------
// Vehicle Model: Car Lineups (e.g. Fortuner, Innova Crysta, Glanza)
// -----------------------------------------------------------------------------
model Vehicle {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  category       String
  description    String?
  heroImage      String?
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED, UPCOMING
  seoTitle       String?
  seoDescription String?
  thumbnail      String?
  gallery        Json?
  brochure       String?
  youtubeUrl     String?
  startingPrice  Float?
  bookingAmount  Float?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  variants            Variant[]
  colors              VehicleColor[]
  testDrives          TestDrive[]
  bookings            Booking[]
  deliveries          Delivery[]
  financeApplications FinanceApplication[]
}

// -----------------------------------------------------------------------------
// Variant Model: Specific models specs (e.g. Innova VX, Fortuner Legender)
// -----------------------------------------------------------------------------
model Variant {
  id           String   @id @default(uuid())
  vehicleId    String
  name         String // e.g. "2.8L 4x4 AT"
  price        Float // Ex-Showroom price for this variant
  fuelType     String // Petrol, Diesel, Hybrid, Electric
  transmission String // Manual, Automatic
  seating      Int      @default(5) // seating capacity
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  specs        Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vehicle    Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  leads      Lead[]
  testDrives TestDrive[]
  bookings   Booking[]
  deliveries Delivery[]
}

// -----------------------------------------------------------------------------
// VehicleColor Model: Color swatches for Toyota vehicle lineup
// -----------------------------------------------------------------------------
model VehicleColor {
  id        String   @id @default(uuid())
  vehicleId String
  name      String // e.g., "Attitude Black"
  colorCode String // e.g., "#1C1C1E" — hex color code for CSS swatch
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Lead Model: Customers inquiring or booking test drives/service
// -----------------------------------------------------------------------------
model Lead {
  id            String    @id @default(uuid())
  branchId      String?
  variantId     String?
  name          String
  email         String
  phone         String
  type          String // TEST_DRIVE, SERVICE, FINANCE, EXCHANGE, GENERAL
  status        String    @default("NEW") // NEW, IN_PROGRESS, COMPLETED, CANCELLED
  source        String    @default("ORGANIC") // ORGANIC, GOOGLE_ADS, META_ADS
  notes         String?
  preferredDate DateTime?
  preferredTime String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  branch     Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  variant    Variant?    @relation(fields: [variantId], references: [id], onDelete: SetNull)
  booking    Booking?
  testDrives TestDrive[]
}

// -----------------------------------------------------------------------------
// Booking Model: Online Vehicle Bookings
// -----------------------------------------------------------------------------
model Booking {
  id                String   @id @default(uuid())
  bookingId         String   @unique // LT-YYYYMM-000001
  customerId        String
  leadId            String?  @unique
  testDriveId       String?  @unique
  vehicleId         String
  variantId         String
  branchId          String
  bookingAmount     Float
  paymentGateway    String? // RAZORPAY, ICICI (make optional to support init state)
  paymentId         String?  @unique // Gateway transaction ref (make optional)
  orderId           String?  @unique // Gateway order ref (make optional)
  paymentStatus     String   @default("PENDING") // PENDING, SUCCESS, FAILED, REFUNDED
  bookingStatus     String   @default("INITIATED") // INITIATED, PAYMENT_PENDING, PAYMENT_SUCCESS, CONFIRMED, VEHICLE_ALLOCATED, DELIVERED, CLOSED, CANCELLED, REFUNDED, EXPIRED
  assignedExecutive String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer           User                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead               Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  testDrive          TestDrive?          @relation(fields: [testDriveId], references: [id], onDelete: SetNull)
  vehicle            Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  variant            Variant             @relation(fields: [variantId], references: [id], onDelete: Cascade)
  branch             Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  payment            Payment?
  delivery           Delivery?
  financeApplication FinanceApplication?
}

// -----------------------------------------------------------------------------
// User Model: Platform Users (Admins, Customers)
// -----------------------------------------------------------------------------
model User {
  id                       String               @id @default(uuid())
  email                    String?              @unique
  phone                    String?              @unique
  passwordHash             String? // Only for ADMIN
  name                     String?
  city                     String?
  state                    String?
  role                     String               @default("CUSTOMER") // ADMIN, CUSTOMER
  address                  String?
  preferredBranchId        String?
  communicationPreferences Json?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  testDrives               TestDrive[]
  bookings                 Booking[]
  payments                 Payment[]
  notifications            Notification[]
  deliveries               Delivery[]
  financeApplications      FinanceApplication[]
  preferredBranch          Branch?              @relation("UserPreferredBranch", fields: [preferredBranchId], references: [id], onDelete: SetNull)
}

// -----------------------------------------------------------------------------
// OtpVerification Model: Dynamic OTP management
// -----------------------------------------------------------------------------
model OtpVerification {
  id        String   @id @default(uuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// TestDrive Model: Dealership test drive appointments
// -----------------------------------------------------------------------------
model TestDrive {
  id                String   @id @default(uuid())
  testDriveId       String   @unique
  customerId        String
  leadId            String?
  vehicleId         String
  variantId         String
  branchId          String
  preferredDate     DateTime
  preferredTime     String
  status            String   @default("REQUESTED") // REQUESTED, CONFIRMED, COMPLETED, BOOKED, CANCELLED, NO_SHOW
  assignedExecutive String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer       User            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead           Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  variant        Variant         @relation(fields: [variantId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  booking        Booking?
  calendarEvents CalendarEvent[]
}

// -----------------------------------------------------------------------------
// CalendarEvent Model: Stores calendar entries (Appointment, Reminder, Completion)
// -----------------------------------------------------------------------------
model CalendarEvent {
  id          String   @id @default(uuid())
  testDriveId String
  type        String // APPOINTMENT, REMINDER, COMPLETION
  title       String
  description String?
  eventDate   DateTime
  provider    String   @default("LOCAL") // LOCAL, GOOGLE, OUTLOOK
  externalId  String? // ID in external calendar provider
  status      String   @default("PENDING") // PENDING, SYNCED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  testDrive TestDrive @relation(fields: [testDriveId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// NotificationLog Model: Keeps track of dispatched notifications
// -----------------------------------------------------------------------------
model NotificationLog {
  id           String   @id @default(uuid())
  bookingId    String?
  deliveryId   String? // Delivery-specific notification reference
  testDriveId  String?
  recipient    String // phone or email
  channel      String // EMAIL, SMS, WHATSAPP, PUSH
  type         String // e.g. BOOKING_CREATED, BOOKING_CONFIRMED, DELIVERY_SCHEDULED, etc.
  status       String // SUCCESS, FAILED, PENDING
  content      String
  errorMessage String?
  createdAt    DateTime @default(now())
}

// -----------------------------------------------------------------------------
// Payment Model: Razorpay Transaction Logs
// -----------------------------------------------------------------------------
model Payment {
  id                String   @id @default(uuid())
  bookingId         String   @unique
  customerId        String
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  amount            Float
  currency          String   @default("INR")
  status            String   @default("CREATED") // CREATED, PENDING, SUCCESS, FAILED, REFUNDED, EXPIRED
  gatewayResponse   Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  booking  Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  audits   PaymentAudit[]
}

// -----------------------------------------------------------------------------
// PaymentAudit Model: Payment status change audit trails
// -----------------------------------------------------------------------------
model PaymentAudit {
  id         String   @id @default(uuid())
  paymentId  String
  fromStatus String
  toStatus   String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Notification Model: Customer portal dynamic notifications
// -----------------------------------------------------------------------------
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  type      String // BOOKING, PAYMENT, TEST_DRIVE, DELIVERY, PROMOTION
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Delivery Model: Vehicle Handover & Delivery Management
// -----------------------------------------------------------------------------
model Delivery {
  id                 String    @id @default(uuid())
  bookingId          String    @unique
  customerId         String
  vehicleId          String
  variantId          String
  branchId           String
  assignedExecutive  String?
  status             String    @default("SCHEDULED") // SCHEDULED, PREPARED, READY, DELIVERED, CANCELLED
  scheduledDate      DateTime?
  actualDeliveryDate DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  booking   Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer  User               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle   Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  variant   Variant            @relation(fields: [variantId], references: [id], onDelete: Cascade)
  branch    Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  checklist DeliveryChecklist?
  timeline  DeliveryTimeline[]
  documents DeliveryDocument[]
}

// -----------------------------------------------------------------------------
// DeliveryChecklist Model: Gate pass criteria verification
// -----------------------------------------------------------------------------
model DeliveryChecklist {
  id                           String   @id @default(uuid())
  deliveryId                   String   @unique
  paymentCleared               Boolean  @default(false)
  insuranceIssued              Boolean  @default(false)
  rtoCompleted                 Boolean  @default(false)
  pdiCompleted                 Boolean  @default(false)
  accessoriesInstalled         Boolean  @default(false)
  fuelFilled                   Boolean  @default(false)
  cleaningCompleted            Boolean  @default(false)
  documentationPrepared        Boolean  @default(false)
  deliveryKitPrepared          Boolean  @default(false)
  customerOrientationCompleted Boolean  @default(false)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// DeliveryTimeline Model: Log audits of handover transitions
// -----------------------------------------------------------------------------
model DeliveryTimeline {
  id           String   @id @default(uuid())
  deliveryId   String
  statusBefore String
  statusAfter  String
  comment      String?
  performedBy  String?
  createdAt    DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// DeliveryDocument Model: Delivery Document Uploads (PDFs, Photos)
// -----------------------------------------------------------------------------
model DeliveryDocument {
  id           String   @id @default(uuid())
  deliveryId   String
  bookingId    String
  uploadedBy   String // user ID or email of uploader
  documentType String // INVOICE, INSURANCE, RC_RECEIPT, CHECKLIST_PDF, DELIVERY_PHOTO, OTHER
  fileName     String // original file name
  storedName   String // sanitized disk file name
  filePath     String // relative server path e.g. uploads/delivery/<deliveryId>/file.pdf
  mimeType     String // application/pdf | image/jpeg | image/png | image/webp
  fileSize     Int // bytes
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// FinanceApplication Model: Finance processing
// -----------------------------------------------------------------------------
model FinanceApplication {
  id                String   @id @default(uuid())
  financeId         String   @unique // LT-FIN-YYYYMM-000001
  bookingId         String   @unique
  customerId        String
  branchId          String
  vehicleId         String
  bankName          String?
  loanAmount        Float?
  downPayment       Float?
  interestRate      Float?
  loanTenure        Int? // in months
  emiAmount         Float?
  status            String   @default("INITIATED") // INITIATED, DOCUMENT_PENDING, UNDER_REVIEW, SANCTION_APPROVED, SANCTION_REJECTED, DISBURSEMENT_PENDING, DISBURSED, CLOSED
  assignedExecutive String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  branch   Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  vehicle  Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  documents FinanceDocument[]
  timelines FinanceTimeline[]
}

// -----------------------------------------------------------------------------
// FinanceDocument Model: Finance Document Uploads
// -----------------------------------------------------------------------------
model FinanceDocument {
  id                   String   @id @default(uuid())
  financeApplicationId String
  documentType         String // AADHAAR, PAN, BANK_STATEMENT, SALARY_SLIP, ITR, SANCTION_LETTER, OTHER
  fileName             String
  storedName           String
  filePath             String
  mimeType             String
  fileSize             Int
  uploadedBy           String
  status               String   @default("PENDING_VERIFICATION") // PENDING_VERIFICATION, VERIFIED, REJECTED
  remarks              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  financeApplication FinanceApplication @relation(fields: [financeApplicationId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// FinanceTimeline Model: Log audits of finance transitions
// -----------------------------------------------------------------------------
model FinanceTimeline {
  id                   String   @id @default(uuid())
  financeApplicationId String
  statusBefore         String
  statusAfter          String
  comment              String?
  performedBy          String?
  createdAt            DateTime @default(now())

  financeApplication FinanceApplication @relation(fields: [financeApplicationId], references: [id], onDelete: Cascade)
}

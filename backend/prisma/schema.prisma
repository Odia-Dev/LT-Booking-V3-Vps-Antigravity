datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// -----------------------------------------------------------------------------
// Branch Model: Dealership Locations
// -----------------------------------------------------------------------------
model Branch {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  address        String
  phone          String
  email          String
  googleMapsUrl  String
  workingHours   String
  managerName    String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leads          Lead[]
}

// -----------------------------------------------------------------------------
// Vehicle Model: Car Lineups (e.g. Fortuner, Innova Crysta, Glanza)
// -----------------------------------------------------------------------------
model Vehicle {
  id               String    @id @default(uuid())
  name             String
  slug             String    @unique
  brand            String    @default("Toyota")
  tagline          String?
  description      String?
  exShowroomMin    Float     // Starting price
  exShowroomMax    Float     // Ending price
  brochureUrl      String?   // Cloudinary PDF link
  status           String    @default("ACTIVE") // ACTIVE, INACTIVE, UPCOMING
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  variants         Variant[]
  colors           VehicleColor[]
}

// -----------------------------------------------------------------------------
// Variant Model: Specific models specs (e.g. Innova VX, Fortuner Legender)
// -----------------------------------------------------------------------------
model Variant {
  id             String   @id @default(uuid())
  vehicleId      String
  name           String   // e.g. "2.8L 4x4 AT"
  fuelType       String   // Petrol, Diesel, Hybrid, Electric
  transmission   String   // Manual, Automatic
  price          Float    // Ex-Showroom price for this variant
  specs          Json     // Key-value specs (engine CC, mileage, seats, etc.)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  leads          Lead[]
}

// -----------------------------------------------------------------------------
// VehicleColor Model: Color swatches and image configuration
// -----------------------------------------------------------------------------
model VehicleColor {
  id         String   @id @default(uuid())
  vehicleId  String
  name       String   // e.g., "Attitude Black"
  hexCode    String   // e.g., "#000000"
  imageUrl   String   // Cloudinary URL for the vehicle in this specific color
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Lead Model: Customers inquiring or booking test drives/service
// -----------------------------------------------------------------------------
model Lead {
  id             String   @id @default(uuid())
  branchId       String?
  variantId      String?
  name           String
  email          String
  phone          String
  type           String   // TEST_DRIVE, SERVICE, FINANCE, EXCHANGE, GENERAL
  status         String   @default("NEW") // NEW, IN_PROGRESS, COMPLETED, CANCELLED
  source         String   @default("ORGANIC") // ORGANIC, GOOGLE_ADS, META_ADS
  notes          String?
  preferredDate  DateTime?
  preferredTime  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch         Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  variant        Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  booking        Booking?
}

// -----------------------------------------------------------------------------
// Booking Model: Upgraded leads making booking payments
// -----------------------------------------------------------------------------
model Booking {
  id             String   @id @default(uuid())
  leadId         String   @unique
  amountPaid     Float
  paymentGateway String   // RAZORPAY, ICICI
  paymentId      String   @unique // Gateway transaction ref
  orderId        String   @unique // Gateway order ref
  paymentStatus  String   @default("PENDING") // PENDING, SUCCESS, FAILED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// User Model: Platform Users (Admins, Customers)
// -----------------------------------------------------------------------------
model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  phone        String?  @unique
  passwordHash String?  // Only for ADMIN
  name         String?
  city         String?
  state        String?
  role         String   @default("CUSTOMER") // ADMIN, CUSTOMER
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// OtpVerification Model: Dynamic OTP management
// -----------------------------------------------------------------------------
model OtpVerification {
  id        String   @id @default(uuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
